---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio cá nhân" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Nguyen Van Hoa</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="text-xl font-bold text-indigo-600 tracking-tight">Hoa's Portfolio</a>
          </div>
          <nav class="flex space-x-8">
            <a href="/" class="text-gray-700 hover:text-indigo-600 font-medium transition-colors">Trang chủ</a>
            <a href="/projects" class="text-gray-700 hover:text-indigo-600 font-medium transition-colors">Dự án</a>
            <a href="/blog" class="text-gray-700 hover:text-indigo-600 font-medium transition-colors">Kiến thức</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto">
      <div class="max-w-5xl mx-auto px-4 py-6 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Nguyễn Văn Hòa. All rights reserved.<br/>
        Built with Astro, Tailwind & TinaCMS
      </div>
    </footer>
  </body>
</html>
