---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portfolio cá nhân" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | HiMo Portfolio</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="bg-gray-950 shadow-lg sticky top-0 z-50 border-b border-indigo-500/20">
      <div class="max-w-[1600px] mx-auto px-4 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex-shrink-0 flex items-center pr-4">
            <a href="/" class="flex items-center gap-3 group">
              <img src="/logo-himo.png" alt="HiMo Logo" class="h-10 w-auto rounded-lg shadow-neon group-hover:scale-110 transition-transform duration-300" />
              <div class="flex flex-col leading-none">
                <span class="text-xl font-bold tracking-tighter text-white group-hover:text-indigo-400 transition-colors">HiMo</span>
                <span class="text-[10px] uppercase tracking-[0.2em] text-indigo-300/70 font-medium whitespace-nowrap">Nguyễn Văn Hoàng</span>
              </div>
            </a>
          </div>
          <!-- Desktop Navigation -->
          <nav class="hidden md:flex space-x-6 items-center">
            <a href="/" class="text-gray-300 hover:text-indigo-400 font-medium transition-colors">Trang chủ</a>
            <a href="/projects" class="text-gray-300 hover:text-indigo-400 font-medium transition-colors">Dự án</a>
            <a href="/blog" class="text-gray-300 hover:text-indigo-400 font-medium transition-colors">Kiến thức</a>
            <a href="/notes" class="text-gray-300 hover:text-indigo-400 font-medium transition-colors">Ghi chú</a>
            <div class="relative group flex items-center justify-end bg-transparent rounded-full border border-transparent hover:border-indigo-100 transition-all focus-within:border-indigo-500 ml-4">
              <input type="text" id="desktop-search-input" placeholder="Nhập để tìm kiếm..." class="w-0 opacity-0 px-0 py-1.5 focus:w-56 focus:opacity-100 focus:px-4 focus:bg-gray-900/80 group-hover:w-56 group-hover:opacity-100 group-hover:px-4 group-hover:bg-gray-900/80 transition-all duration-300 rounded-l-full outline-none text-sm z-10 bg-transparent placeholder-indigo-400/50 text-indigo-100 border-none cursor-text" />
              <button id="desktop-search-btn" class="p-2 text-gray-400 group-hover:text-indigo-400 rounded-r-full transition-colors z-20 focus:outline-none" title="Tìm kiếm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              </button>
            </div>
          </nav>

          <!-- Mobile Right Items -->
          <div class="flex md:hidden items-center space-x-2">
            <div class="relative flex items-center justify-end w-8 h-8">
              <input type="text" id="mobile-search-input" placeholder="Tìm kiếm..." class="absolute right-0 w-8 opacity-0 focus:w-[150px] focus:opacity-100 px-4 py-1.5 pr-8 bg-gray-900 border border-indigo-500/30 focus:border-indigo-400 focus:shadow-neon transition-all duration-300 rounded-full outline-none text-sm z-40 placeholder-gray-500 text-indigo-100 overflow-hidden" />
              <button id="mobile-search-btn" class="absolute right-0 p-1.5 text-gray-400 hover:text-indigo-400 rounded-full transition-colors z-50 bg-transparent border-none focus:outline-none" title="Tìm kiếm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Curved Magic Menu (Mobile) -->
    <div class="magic-nav z-50 md:!hidden">
      <ul class="magic-nav-list">
        <div id="magic-indicator" class="magic-indicator"></div>
        <li class="magic-nav-item active" data-path="/">
          <a href="/">
            <span class="icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg></span>
            <span class="text">Trang chủ</span>
          </a>
        </li>
        <li class="magic-nav-item" data-path="/projects">
          <a href="/projects">
            <span class="icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg></span>
            <span class="text">Dự án</span>
          </a>
        </li>
        <li class="magic-nav-item" data-path="/blog">
          <a href="/blog">
            <span class="icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg></span>
            <span class="text">Blog</span>
          </a>
        </li>
        <li class="magic-nav-item" data-path="/notes">
          <a href="/notes">
            <span class="icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg></span>
            <span class="text">Ghi chú</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Main Layout Wrapper 3 Cột -->
    <div class="flex-grow w-full px-2 sm:px-4 2xl:px-8 flex flex-row justify-between">
      
      <!-- Cột Trái chứa Quảng cáo (Dính sát viền trái màn hình) -->
      <aside class="hidden xl:block w-[160px] 2xl:w-[250px] flex-shrink-0 py-10">
        <div class="sticky top-24 bg-indigo-50/50 rounded-xl h-[500px] flex flex-col items-center justify-center text-indigo-300 border-2 border-dashed border-indigo-100 text-sm font-medium text-center p-4">
          <svg class="w-8 h-8 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Banner Khuyến mãi
        </div>
      </aside>

      <!-- Nội dung chính (Tràn 100% khung giữa) -->
      <main class="flex-grow w-full py-8 sm:py-10 px-4 lg:px-6 pb-24 md:pb-10">
        <slot />
      </main>

      <!-- Cột Phải chứa Quảng cáo (Dính sát viền phải màn hình) -->
      <aside class="hidden xl:block w-[160px] 2xl:w-[250px] flex-shrink-0 py-10">
        <div class="sticky top-24 bg-indigo-50/50 rounded-xl h-[500px] flex flex-col items-center justify-center text-indigo-300 border-2 border-dashed border-indigo-100 text-sm font-medium text-center p-4">
          <svg class="w-8 h-8 mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          Kiếm tiền Adsense
        </div>
      </aside>
      
    </div>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto shrink-0 w-full relative z-20 pb-20 md:pb-8">
      <div class="max-w-[1600px] mx-auto px-4 py-8 flex flex-col items-center justify-center text-sm text-gray-500">
        <p>&copy; {new Date().getFullYear()} Nguyễn Văn Hoàng. All rights reserved.</p>
        <p class="mt-1">
          Built with Astro, Tailwind & <a href="/admin/index.html" class="text-indigo-600 hover:underline font-medium" target="_blank">Decap CMS</a>
        </p>
      </div>
    </footer>
    
    <!-- Nút Cuộn lên đầu trang (Scroll to Top) -->
    <button id="scroll-to-top" class="fixed bottom-8 right-8 md:bottom-12 md:right-12 bg-indigo-600 text-white p-3 rounded-full shadow-2xl opacity-0 invisible hover:-translate-y-1 hover:bg-indigo-700 transition-all duration-300 z-50" title="Lên đầu trang">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
    </button>

    <style is:global>
      /* --- SLIM MAGIC MENUBAR CSS (CODEHAL PATTERN FIX) --- */
      .magic-nav {
        position: fixed; bottom: 0; width: 100%; height: 50px; /* Nhỏ gọn hơn */
        background: linear-gradient(135deg, #fdfbfb 0%, #f3f4f6 100%); /* Nền Gradient Sinh động */
        display: flex; justify-content: center; align-items: center;
        border-radius: 12px 12px 0 0;
        box-shadow: 0 -5px 15px rgba(0,0,0,0.05);
      }
      .magic-nav-list {
        display: flex; width: 100%; max-width: 400px; position: relative; justify-content: space-around;
      }
      .magic-nav-item {
        position: relative; list-style: none; width: 50px; height: 50px; z-index: 10;
      }
      .magic-nav-item a {
        position: relative; display: flex; justify-content: center; align-items: center;
        flex-direction: column; width: 100%; text-align: center; font-weight: 500; height: 100%;
      }
      .magic-nav-item .icon {
        position: absolute; display: flex; justify-content: center; align-items: center; transition: 0.5s;
        width: 100%; height: 50px; /* Center SVG perfectly inside the 50px block */
        color: #9ca3af; /* Gray-400 */
      }
      /* Kéo icon lên khi Active */
      .magic-nav-item.active .icon {
        transform: translateY(-25px); /* Khớp tuyệt đối với tâm của Indicator width 50 */
        color: var(--active-color, #ec4899);
      }
      .magic-nav-item .text {
        position: absolute; color: var(--active-color, #4f46e5); font-size: 0.60em; letter-spacing: 0.05em;
        transition: 0.5s; opacity: 0; transform: translateY(20px); font-weight: bold;
      }
      .magic-nav-item.active .text {
        opacity: 1; transform: translateY(12px);
      }
      
      .magic-indicator {
        position: absolute; top: -50%; left: 0; /* THÊM left:0 ĐỂ TRÁNH LỖI VỊ TRÍ FLEXBOX */
        width: 50px; height: 50px;
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); /* Nền nhạt bên trong viên nang */
        border-radius: 50%;
        border: 4px solid var(--active-color, #ec4899); /* Viền màu động ôm trọn vòm */
        transition: 0.5s cubic-bezier(0.68, -0.55, 0.26, 1.55);
      }
      /* Cánh vòm bên trái (Wing Effect) */
      .magic-indicator::before {
        content: ''; position: absolute; top: 50%; left: -18px; width: 15px; height: 15px;
        background: transparent; border-top-right-radius: 15px;
        box-shadow: 0px -4px 1px -1px var(--active-color, #ec4899);
      }
      /* Cánh vòm bên phải (Wing Effect) */
      .magic-indicator::after {
        content: ''; position: absolute; top: 50%; right: -18px; width: 15px; height: 15px;
        background: transparent; border-top-left-radius: 15px;
        box-shadow: 0px -4px 1px -1px var(--active-color, #ec4899);
      }

      /* CSS Animation cho tiêu đề Gradient */
      @keyframes gradient-move {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }
      .animate-gradient {
        background-size: 200% auto;
        animation: gradient-move 4s linear infinite;
      }
      .shadow-neon {
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.4), 0 0 5px rgba(99, 102, 241, 0.2);
      }
    </style>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {

        // --- TÍNH NĂNG 1: MAGIC BOTTOM NAVIGATION (MOBILE CURVED) ---
        const navItems = document.querySelectorAll('.magic-nav-item');
        const indicator = document.getElementById('magic-indicator');
        const currentPath = window.location.pathname;

        if (navItems.length > 0 && indicator) {
          // Bảng màu 4 Tabs (Hồng, Tím, Xanh ngọc, Xanh lục)
          const tabColors = ['#ec4899', '#8b5cf6', '#06b6d4', '#10b981'];
          const navList = document.querySelector('.magic-nav-list');

          let activeItem = Array.from(navItems).find(item => 
            (item.getAttribute('data-path') !== '/' && currentPath.includes(item.getAttribute('data-path'))) ||
            (item.getAttribute('data-path') === '/' && currentPath === '/')
          ) || navItems[0];
          
          const moveIndicator = (item) => {
            if (!item || !indicator) return;
            const itemRect = item.getBoundingClientRect();
            const parentRect = navList.getBoundingClientRect();
            
            // Dịch chuyển vòng tròn indicator
            indicator.style.transform = `translateX(${itemRect.left - parentRect.left}px)`;
            
            // Lấy Tab Index để đổi màu sinh động
            const index = Array.from(navItems).indexOf(item);
            navList.style.setProperty('--active-color', tabColors[index % tabColors.length]);

            navItems.forEach(i => i.classList.remove('active'));
            item.classList.add('active');
          };

          // Khởi tạo vị trí
          setTimeout(() => moveIndicator(activeItem), 100);

          navItems.forEach(item => {
            item.addEventListener('click', () => moveIndicator(item));
          });
        }

        // --- TÍNH NĂNG 1.5: SEARCH BẮT SỰ KIỆN ENTER VÀ CLICK CHUỘT ---
        const searchInput = document.getElementById('desktop-search-input');
        const searchBtn = document.getElementById('desktop-search-btn');
        const mobileSearchInput = document.getElementById('mobile-search-input');
        const mobileSearchBtn = document.getElementById('mobile-search-btn');

        // Hàm xử lý search chung
        const executeSearch = (inputEl) => {
          const val = inputEl.value.trim();
          if (val !== '') {
            window.location.href = '/search?q=' + encodeURIComponent(val);
          } else {
            inputEl.focus(); // Nếu input rỗng thì focus mở rộng ra
          }
        };

        // Bắt sự kiện phím Enter
        const handleKeypress = (e) => {
          if (e.key === 'Enter') executeSearch(e.target);
        };
        if (searchInput) searchInput.addEventListener('keypress', handleKeypress);
        if (mobileSearchInput) mobileSearchInput.addEventListener('keypress', handleKeypress);

        // Bắt sự kiện Click nút kính lúp
        if (searchBtn && searchInput) {
          searchBtn.addEventListener('click', () => executeSearch(searchInput));
        }
        if (mobileSearchBtn && mobileSearchInput) {
          mobileSearchBtn.addEventListener('click', () => executeSearch(mobileSearchInput));
        }

        // --- TÍNH NĂNG 2: SCROLL TO TOP ---
        const scrollBtn = document.getElementById('scroll-to-top');
        if (scrollBtn) {
          // Lắng nghe sự kiện cuộn chuột của toàn bộ trang window
          window.addEventListener('scroll', () => {
            // Nếu cuộn xuống quá 300px, hiển thị nút lên (xoá class tàng hình)
            if (window.scrollY > 300) {
              scrollBtn.classList.remove('opacity-0', 'invisible');
              scrollBtn.classList.add('opacity-100', 'visible');
            } else {
              scrollBtn.classList.add('opacity-0', 'invisible');
              scrollBtn.classList.remove('opacity-100', 'visible');
            }
          });
          // Bấm nút sẽ trigger hàm scrollTo vị trí y=0 (Đầu trang) kèm hiệu ứng mượt (smooth)
          scrollBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      });
    </script>
  </body>
</html>
