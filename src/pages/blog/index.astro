---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Kiến thức lập trình">
  <div class="w-full mx-auto py-12 px-4 sm:px-6">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8 tracking-tight">Blog & Ghi chú</h1>
    
    <div class="space-y-8">
      {posts.length === 0 ? (
        <p class="text-gray-500">Chưa có bài viết nào.</p>
      ) : (
        posts.map((post) => (
          <article class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <h2 class="text-2xl font-bold text-gray-900 mb-3">
              <a href={`${base}/blog/${post.slug}`} class="hover:text-indigo-600 transition-colors">
                {post.data.title}
              </a>
            </h2>
            {post.data.date && <time class="text-sm text-gray-500 block mb-4">{post.data.date.toLocaleDateString('vi-VN')}</time>}
            <p class="text-gray-600 mb-4">{post.data.excerpt}</p>
            <a href={`${base}/blog/${post.slug}`} class="inline-flex items-center text-indigo-600 font-semibold group">
              Đọc tiếp
              <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </article>
        ))
      )}
    </div>
  </div>
</Layout>
