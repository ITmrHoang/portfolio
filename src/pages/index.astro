---
import Layout from '../layouts/Layout.astro';
import client from '../../tina/__generated__/client';

// Fetch max 3 recent projects
const projectsRes = await client.queries.projectsConnection({ first: 3 });
const projects = projectsRes.data?.projectsConnection?.edges?.map(e => e?.node) || [];

// Fetch max 3 recent blogs
const blogsRes = await client.queries.blogConnection({ first: 3, sort: 'date' });
const blogs = blogsRes.data?.blogConnection?.edges?.map(e => e?.node) || [];
---

<Layout title="Trang Chủ">
  <section class="text-center py-20 px-4">
    <h1 class="text-5xl font-extrabold tracking-tight text-gray-900 sm:text-6xl mb-6">
      Xin chào, tôi là <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">Hòa</span>
    </h1>
    <p class="mt-4 max-w-2xl mx-auto text-xl text-gray-500">
      Web Developer đam mê xây dựng các sản phẩm thực tế, đẹp mắt và tốc độ cao. Dưới đây là những dự án tôi đã làm và kiến thức tôi chắt lọc được.
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a href="/projects" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-full shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 transition">
        Xem Dự Án
      </a>
      <a href="/blog" class="inline-flex items-center px-6 py-3 border border-gray-300 shadow-sm text-base font-medium rounded-full text-gray-700 bg-white hover:bg-gray-50 transition">
        Đọc Blog
      </a>
    </div>
  </section>

  <!-- Projects Preview Section -->
  {projects.length > 0 && (
    <section class="py-12 border-t border-gray-200">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900">Dự án nổi bật</h2>
        <a href="/projects" class="text-indigo-600 hover:text-indigo-800 font-medium group flex items-center">
          Xem tất cả <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
            {project?.coverImage && (
              <img src={project.coverImage} alt={project.title} class="w-full h-48 object-cover" />
            )}
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">{project?.title}</h3>
              <p class="text-gray-500 line-clamp-3 mb-4">{project?.description}</p>
              <a href={`/projects/${project?._sys.filename}`} class="text-indigo-600 font-medium hover:underline">Chi tiết</a>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Blog Preview Section -->
  {blogs.length > 0 && (
    <section class="py-12 border-t border-gray-200">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900">Bài viết mới nhất</h2>
        <a href="/blog" class="text-indigo-600 hover:text-indigo-800 font-medium group flex items-center">
          Xem tất cả <span class="ml-1 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
      <div class="space-y-6">
        {blogs.map((post) => (
          <article class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:border-indigo-100 transition-colors">
            <h3 class="text-2xl font-bold text-gray-900 mb-2">
              <a href={`/blog/${post?._sys.filename}`} class="hover:text-indigo-600 transition-colors">{post?.title}</a>
            </h3>
            {post?.date && <time class="text-sm text-gray-500 block mb-3">{new Date(post.date).toLocaleDateString('vi-VN')}</time>}
            <p class="text-gray-600">{post?.excerpt}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</Layout>
