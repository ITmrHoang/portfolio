---
import NotesLayout from '../../layouts/NotesLayout.astro';
import { getCollection } from 'astro:content';
import { Callout } from '../../components/react/Callout';

export async function getStaticPaths() {
  const entries = await getCollection('notes');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const components = { Callout };
---

<NotesLayout title={entry.data.title} currentSlug={entry.slug}>
  <article class="bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-gray-100 h-full">
    <header class="mb-10 border-b border-gray-100 pb-8 text-center md:text-left">
      <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-50 text-indigo-700 mb-4">
        📁 {entry.data.topic}
      </div>
      <h1 class="text-3xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4 leading-tight">{entry.data.title}</h1>
      {entry.data.date && <time class="text-gray-500 font-medium">⏳ Đăng ngày: {entry.data.date.toLocaleDateString('vi-VN')}</time>}
    </header>

    <div class="prose prose-lg prose-indigo mx-auto md:mx-0 text-gray-800 max-w-none">
      <Content components={components} />
    </div>

    <footer class="mt-16 pt-8 border-t border-gray-100 flex items-center justify-between">
      <a href="/notes" class="inline-flex items-center px-4 py-2 bg-gray-50 text-gray-700 rounded-xl hover:bg-indigo-50 hover:text-indigo-600 font-medium transition-colors">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Trở về danh mục
      </a>
      <a href="#" class="inline-flex items-center px-4 py-2 text-gray-500 hover:text-indigo-600 transition-colors">
        Lên góc trên ↑
      </a>
    </footer>
  </article>
</NotesLayout>
