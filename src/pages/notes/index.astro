---
import NotesLayout from '../../layouts/NotesLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const notes = allNotes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Group notes by topic
const topicMap = new Map();
for (const note of notes) {
  const topic = note.data.topic;
  if (!topicMap.has(topic)) topicMap.set(topic, []);
  topicMap.get(topic).push(note);
}
const topics = [...topicMap.entries()];
---

<NotesLayout title="Sổ tay ghi chú">
  <div class="bg-white rounded-3xl p-8 sm:p-10 shadow-sm border border-gray-100 h-full">
    <header class="mb-8 border-b border-gray-100 pb-8 text-center md:text-left">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">
        Sổ tay của tôi
      </h1>
      <p class="text-lg text-gray-500">Nơi chắt lọc những kiến thức và thủ thuật lập trình đắt giá nhất.</p>
      <p class="text-sm text-gray-400 mt-2">Tổng cộng {notes.length} bài viết</p>
    </header>

    {topics.map(([topic, topicNotes], index) => (
      <details class="mb-6 group/topic border border-gray-100 rounded-2xl overflow-hidden" open={index === 0 || undefined}>
        <summary class="flex items-center justify-between cursor-pointer px-6 py-4 bg-gray-50/80 hover:bg-indigo-50/50 transition-colors select-none list-none">
          <div class="flex items-center gap-3">
            <span class="inline-block px-3 py-1 bg-indigo-100 text-indigo-700 text-sm font-bold rounded-lg">{topic}</span>
            <span class="text-sm text-gray-400">({topicNotes.length} bài)</span>
          </div>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open/topic:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </summary>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 p-5">
          {topicNotes.map(note => (
            <a href={`${base}/notes/${note.slug}`} class="block p-5 border border-indigo-50 rounded-2xl bg-indigo-50/30 hover:bg-indigo-50 hover:border-indigo-100 transition-all group">
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-indigo-600 transition-colors mb-2">{note.data.title}</h3>
              <span class="text-sm text-gray-500">{note.data.date.toLocaleDateString('vi-VN')}</span>
            </a>
          ))}
        </div>
      </details>
    ))}
  </div>
</NotesLayout>
