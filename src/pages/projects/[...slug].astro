---
import Layout from '../../layouts/Layout.astro';
import { RichTextRenderer } from '../../components/react/RichTextRenderer';
import client from '../../../tina/__generated__/client';

export async function getStaticPaths() {
  const projectsRes = await client.queries.projectsConnection();
  const edges = projectsRes.data.projectsConnection.edges || [];
  
  return edges.map((edge) => ({
    params: { slug: edge?.node?._sys.filename },
    props: { project: edge?.node },
  }));
}

const { project } = Astro.props;
---

<Layout title={project?.title || 'Dự án'}>
  <article class="max-w-4xl mx-auto py-12 px-4 sm:px-6">
    <header class="mb-10 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">{project?.title}</h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto">{project?.description}</p>
      
      {project?.technologies && project.technologies.length > 0 && (
        <div class="mt-6 flex flex-wrap justify-center gap-2">
          {project.technologies.map(tech => (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
              {tech}
            </span>
          ))}
        </div>
      )}
    </header>

    {project?.coverImage && (
      <div class="mb-12 rounded-2xl overflow-hidden shadow-xl border border-gray-100">
        <img src={project.coverImage} alt={project.title} class="w-full h-auto object-cover max-h-[500px]" />
      </div>
    )}

    <div class="mt-8 border-t border-gray-100 pt-8 max-w-3xl mx-auto">
      <!-- Mấu chốt: Nhúng Component React & MDX -->
      <RichTextRenderer content={project?.body} client:idle />
    </div>

    <div class="mt-16 text-center border-t border-gray-100 pt-8">
      <a href="/projects" class="text-indigo-600 hover:text-indigo-800 font-medium inline-flex items-center">
        ← Quay lại danh sách dự án
      </a>
    </div>
  </article>
</Layout>
