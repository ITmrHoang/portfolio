---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tìm kiếm">
  <div class="max-w-3xl mx-auto py-12 px-4 sm:px-6">
    <header class="mb-10 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">
        Tìm kiếm hệ thống
      </h1>
      <p class="text-xl text-gray-500">Tra cứu nhanh mọi bài viết, ghi chú và dự án.</p>
    </header>

    <div class="bg-white rounded-3xl p-6 sm:p-10 shadow-sm border border-gray-100 min-h-[500px]">
      <div id="search" class="w-full"></div>
    </div>
  </div>
</Layout>

<!-- Pagefind Styles & Script -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<style is:global>
  /* Ghi đè CSS của Pagefind cho đẹp hơn với Tailwind */
  :root {
    --pagefind-ui-primary: #4f46e5;
    --pagefind-ui-text: #1f2937;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: #e0e7ff;
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-font: 'Inter', sans-serif;
  }
  .pagefind-ui__search-input {
    font-weight: 500 !important;
  }
</style>

<script is:inline>
  window.addEventListener('DOMContentLoaded', (event) => {
    // Chỉ load pagefind trong môi trường build đã có thư mục tự render
    if (typeof PagefindUI !== 'undefined') {
      new PagefindUI({ element: "#search", showSubResults: true, showImages: false });

      // Lấy từ khoá tìm kiếm từ Header truyền sang (nếu có)
      const urlParams = new URLSearchParams(window.location.search);
      const query = urlParams.get('q');
      if (query) {
        // Delay 100ms để đợi thư viện Pagefind sinh ra thẻ input HTML rồi nhảy vào điền Text
        setTimeout(() => {
          const inputEl = document.querySelector('.pagefind-ui__search-input');
          if (inputEl) {
            inputEl.value = query;
            inputEl.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }, 150);
      }
    } else {
      document.getElementById('search').innerHTML = '<p class="text-red-500 text-center mt-10">Lưu ý: Tính năng tìm kiếm chỉ hoạt động sau khi chạy lệnh <code>npm run build</code>.</p>';
    }
  });
</script>
<script src="/pagefind/pagefind-ui.js" is:inline></script>
